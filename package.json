{
  "name": "collection-studio-pro",
  "version": "0.1.0",
  "private": true,
  "description": "Collection Studio Pro",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.collectionstudio.pro",
    "productName": "Collection Studio Pro",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
